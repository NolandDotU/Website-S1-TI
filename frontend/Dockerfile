# Stage 1: Build React app
FROM node:20-alpine AS builder

WORKDIR /app

COPY package*.json ./

ARG REACT_APP_BACKEND_URL
ARG REACT_APP_URL_LOGIN_GOOGLE
ARG REACT_APP_BACKEND_URL_VERSION
ARG REACT_APP_IMAGE_BASE_URL

ENV REACT_APP_BACKEND_URL=$REACT_APP_BACKEND_URL
ENV REACT_APP_URL_LOGIN_GOOGLE=$REACT_APP_URL_LOGIN_GOOGLE
ENV REACT_APP_BACKEND_URL_VERSION=$REACT_APP_BACKEND_URL_VERSION
ENV REACT_APP_IMAGE_BASE_URL=$REACT_APP_IMAGE_BASE_URL

RUN npm ci

COPY . .
RUN npm run build


# Stage 2: Serve build with lightweight static server
FROM node:20-alpine

WORKDIR /app

RUN npm install -g serve

COPY --from=builder /app/build ./build

EXPOSE 3000

CMD ["serve", "-s", "build", "-l", "tcp://0.0.0.0:3000"]